# Postgres (Neon) — mesmo banco do app Next.js. Este serviço conecta como
# service_role (BYPASSRLS), então não precisa dos claims/withClaims do app.
DATABASE_URL=postgresql://app_user:PASSWORD@ep-PROJECT_ID-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Chave de criptografia das API keys por tenant — mesma do apps/web.
ENCRYPTION_KEY=

# Porta HTTP do serviço (webhook + send-whatsapp)
PORT=3001

# Token esperado no header Authorization: Bearer <token> das chamadas do
# Next.js pra POST /send-whatsapp. Deixe vazio para desabilitar a checagem
# (não recomendado em produção).
BACKEND_TOKEN=

# Cloudinary — upload de áudio recebido do WhatsApp
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Fallbacks globais de LLM (usados só se o tenant não tiver chave própria)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
