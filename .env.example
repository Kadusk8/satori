# ── Neon (Postgres) ──────────────────────────────────────────────
# Usuário de conexão precisa ser membro dos roles `authenticated` e
# `service_role` (ver neon/schema.sql). NÃO deve ter BYPASSRLS próprio.
DATABASE_URL=postgresql://app_user:PASSWORD@ep-PROJECT_ID-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Chave de criptografia das API keys por tenant (evolution/LLM).
# Também configure no banco: ALTER DATABASE <db> SET app.encryption_key = '...';
ENCRYPTION_KEY=

# ── Auth.js (NextAuth v5) ────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET=
# URL pública do app (usada nos links de email de reset/convite)
NEXT_PUBLIC_APP_URL=https://app.zapagent.com

# ── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=ZapAgent <no-reply@seudominio.com>

# ── Realtime (Pusher) ────────────────────────────────────────────
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
PUSHER_APP_ID=
PUSHER_SECRET=

# ── Cloudinary (imagens de produto direto do browser) ────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# ── Serviço backend (Fase 5 — webhook, IA, cron; ver services/backend) ──
# BACKEND_URL: usado pelo Next.js pra chamar POST /send-whatsapp (envio manual
# do CRM). BACKEND_PUBLIC_URL: URL pública registrada como webhook na
# Evolution Go no onboarding (pode ser igual a BACKEND_URL).
BACKEND_URL=https://backend.seudominio.com
BACKEND_PUBLIC_URL=https://backend.seudominio.com
BACKEND_TOKEN=

# ── IA / LLM (fallback global — usado pelo serviço backend) ──────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
